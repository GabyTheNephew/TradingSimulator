# ==========================================
# ANGULAR / NODE.JS (Frontend)
# ==========================================
# Pachete descarcate (se regenereaza cu npm install)
node_modules/

# Fisiere de build (compilate)
dist/
tmp/
out-tsc/
bazel-out/

# Cache Angular si log-uri de eroare
.angular/
npm-debug.log
yarn-error.log
*npm-debug.log*

# Rapoarte de testare
coverage/

# ==========================================
# .NET / C# (Backend)
# ==========================================
# Fisiere compilate si binare (se regenereaza la Build)
[Bb]in/
[Oo]bj/

# Fisiere si foldere specifice Visual Studio / Rider
.vs/
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates

# Fisiere de setari locale (Daca ai parole/chei de API in ele, decomenteaza linia de mai jos)
# appsettings.Development.json
# secrets.json

# Baze de date locale (daca folosesti SQLite de exemplu in teste)
*.db
*.sqlite3

